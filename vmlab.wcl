// -----------------------------------------------------------------------------
// templeos

// TempleOS template (PRD §6.1). Terry A. Davis's public-domain 64-bit hobby
// OS (templeos.org), booted from the official ISO and auto-installed onto a
// blank RedSea disk.
//
// TempleOS is public domain, so — unlike the proprietary/MS vintage entries —
// it is freely redistributable and carries a `registry`. The ISO is downloaded
// and sha256-verified into the artefact cache; no fetch-deps step.
//
// It has no networking and no way to run the vmlab guest agent, so the template
// carries `agent = false`: clones never report `ready` and have no exec/cp/
// terminal. The CD's `#include "Once"` installer is driven over the live screen
// (VNC keystrokes + image matching — TempleOS's bitmap font defeats OCR); see
// scripts/install.ws.
//
// The windows-legacy profile fits it well: i440fx + SeaBIOS (TempleOS wants a
// legacy-BIOS MBR boot), an IDE/ATA disk (its only disk driver), and plain std
// VGA (it drives VBE directly). The e1000 NIC the profile adds is unused.


template "templeos" {
  arch     = "x86_64"
  version  = "5.03"
  registry = "ghcr.io/vmlabdev/vmlab-templates/templeos"
  profile  = "windows-legacy"
  agent    = false
  cpus     = 2
  memory   = 512MiB
  disk     = 2GiB

  source "iso" {
    url    = "https://templeos.org/Downloads/TempleOS.ISO"
    sha256 = "5d0fc944e5d89c155c0fc17c148646715bc1db6fa5750c0b913772cfec19ba26"
  }

  provision "templeos/scripts/install.ws" { }
}

// -----------------------------------------------------------------------------
// ubuntu-24.04

// Ubuntu Server 24.04 template (PRD §6.1). The installer ISO is downloaded
// and sha256-verified into the artefact cache; cloudinit/ is packed into a
// CIDATA ISO that subiquity picks up as a NoCloud autoinstall source. The
// provision script answers the autoinstall confirmation and waits for the
// installer to power the VM off. Build with:
//
//   vmlab template build        (run from this directory)


template "ubuntu-24.04" {
  arch    = "x86_64"
  version = "24.04.4"
  registry = "ghcr.io/vmlabdev/vmlab-templates/ubuntu-24.04"
  profile = "linux-modern"
  cpus    = 2
  memory  = 4GiB
  disk    = 20GiB

  source "iso" {
    url    = "https://releases.ubuntu.com/24.04/ubuntu-24.04.4-live-server-amd64.iso"
    sha256 = "e907d92eeec9df64163a7e454cbc8d7755e8ddc7ed42f99dbc80c40f1a138433"
  }

  media { kind = "iso" from = "./ubuntu-24.04/cloudinit/" label = "CIDATA" }
  nic { nat = true }

  provision "ubuntu-24.04/scripts/install.ws" { }
}

// -----------------------------------------------------------------------------
// ubuntu-26.04

// Ubuntu Server 26.04 LTS template (PRD §6.1), built from the official
// cloud image + cloud-init (simpler than the 24.04 subiquity ISO install).
// The qcow2 is downloaded and sha256-verified into the artefact cache;
// cloudinit/ is packed into a CIDATA ISO (NoCloud datasource) that creates
// the vmlab login and installs the vmlab guest agent on first boot.
//
//   vmlab template build        (run from this directory)
//
// The cloud image in releases/26.04/release/ is periodically respun; if the
// sha256 stops matching, refresh it from
// https://cloud-images.ubuntu.com/releases/26.04/release/SHA256SUMS


template "ubuntu-26.04" {
  arch     = "x86_64"
  version  = "26.04"
  registry = "ghcr.io/vmlabdev/vmlab-templates/ubuntu-26.04"
  profile  = "linux-modern"
  firmware = "seabios"
  cpus     = 2
  memory   = 4GiB
  disk     = 20GiB

  source "qcow2" {
    url    = "https://cloud-images.ubuntu.com/releases/26.04/release/ubuntu-26.04-server-cloudimg-amd64.img"
    sha256 = "dced94c031cc1f23dee14419a3723a5b110df9938de0ac31913a2bfd07c755b4"
  }

  media { kind = "iso" from = "./ubuntu-26.04/cloudinit/" label = "CIDATA" }
  nic { nat = true }

  provision "ubuntu-26.04/scripts/install.ws" { }
}

// -----------------------------------------------------------------------------
// ubuntu-arm64

// Ubuntu Server 24.04 LTS (noble) for arm64/aarch64. Unlike the x86
// ubuntu-24.04 template (installer ISO + subiquity autoinstall), the arm64
// build uses the official cloud image qcow2 + cloud-init — far faster
// under TCG and consistent with the other arm64 cloud-image templates.
// Runs under TCG on x86 hosts (no KVM) — slow but functional. cloud-init
// picks up the CIDATA seed (NoCloud), creates vmlab/vmlab and installs the
// vmlab guest agent. Build with:
//
//   vmlab template build        (run from this directory)
//
// Image pinned to cloud build serial 20260518; sha256 from the official
// cloud-images.ubuntu.com SHA256SUMS.


template "ubuntu-24.04" {
  arch     = "aarch64"
  version  = "24.04"
  registry = "ghcr.io/vmlabdev/vmlab-templates/ubuntu-24.04"
  profile  = "linux-modern"
  firmware = "ovmf"
  cpus     = 2
  memory   = 2GiB
  disk     = 20GiB

  source "qcow2" {
    url    = "https://cloud-images.ubuntu.com/noble/20260518/noble-server-cloudimg-arm64.img"
    sha256 = "6a61b967ba4a27dd1966f835a67643073ed55c2860ce3dc1cb0517282e6b8bec"
  }

  media { kind = "iso" from = "./ubuntu-arm64/cloudinit/" label = "CIDATA" }
  nic { nat = true }

  provision "ubuntu-arm64/scripts/install.ws" { }
}

// -----------------------------------------------------------------------------
