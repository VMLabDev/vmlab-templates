// Generated by scripts/generate-unified-wcl.sh from the standalone template
// definitions. Edit the per-template vmlab.wcl files, then regenerate.

import <vmlab.wcl>

// The empty lab makes this repository discoverable by vmlab-web. Template
// builds are driven from the Templates tab; there are no ordinary lab VMs.
lab "templates" { }

// -----------------------------------------------------------------------------
// almalinux-10

// AlmaLinux 10 template (PRD §6.1), built from the official GenericCloud
// image + cloud-init. One of the two community RHEL rebuilds (alongside
// Rocky). The qcow2 is downloaded and sha256-verified into the artefact
// cache; cloudinit/ is packed into a CIDATA ISO (NoCloud datasource) that
// creates the vmlab login and installs the vmlab guest agent on first boot.
//
//   vmlab template build        (run from this directory)
//
// Point-release bumps: update the url, sha256 (from the CHECKSUM beside the
// image under https://repo.almalinux.org/almalinux/10/cloud/x86_64/images/),
// and version.


template "almalinux-10" {
  arch     = "x86_64"
  version  = "10.2"
  registry = "ghcr.io/vmlabdev/vmlab-templates/almalinux-10"
  profile  = "linux-modern"
  firmware = "seabios"
  cpus     = 2
  memory   = 4GiB
  disk     = 20GiB

  source "qcow2" {
    url    = "https://repo.almalinux.org/almalinux/10/cloud/x86_64/images/AlmaLinux-10-GenericCloud-10.2-20260526.0.x86_64.qcow2"
    sha256 = "47f2218668dd4776be140dd92fa3bea700be1766e2c7d88bdfd6a4b50f477b4d"
  }

  media { kind = "iso" from = "./almalinux-10/cloudinit/" label = "CIDATA" }
  nic { nat = true }

  provision "almalinux-10/scripts/install.ws" { }
}

// -----------------------------------------------------------------------------
// alpine-3.23-arm64

// Alpine Linux 3.23 for arm64/aarch64, built from the official NoCloud
// cloud image (UEFI, cloud-init variant). Runs under TCG on x86 hosts (no
// KVM) — slow but functional. cloud-init picks up the CIDATA seed, creates
// vmlab/vmlab and installs the vmlab guest agent (VMLAB bootstrap ISO). Build with:
//
//   vmlab template build        (run from this directory)
//
// Image sha512-verified against dl-cdn.alpinelinux.org, sha256 computed
// from the verified file.


template "alpine-3.23" {
  arch     = "aarch64"
  version  = "3.23"
  registry = "ghcr.io/vmlabdev/vmlab-templates/alpine-3.23"
  profile  = "linux-modern"
  firmware = "ovmf"
  cpus     = 1
