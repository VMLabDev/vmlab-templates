  disk     = 10GiB

  source "qcow2" {
    url    = "https://dl-cdn.alpinelinux.org/alpine/v3.23/releases/cloud/nocloud_alpine-3.23.4-aarch64-uefi-cloudinit-r0.qcow2"
    sha256 = "eeda75c83fcade4c9f0c461c923b965df0fb1b294e5c66d4ef09ed0dc2ad360c"
  }

  media { kind = "iso" from = "./alpine-3.23-arm64/cloudinit/" label = "CIDATA" }
