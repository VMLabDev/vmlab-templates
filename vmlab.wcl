// -----------------------------------------------------------------------------
// windows-2000

// windows-2000 template (PRD §6.1). Windows 2000 Professional SP4 on the
// windows-9x profile (i440fx/SeaBIOS/IDE, Cirrus VGA, AMD PCnet NIC). The
// bootable CD installs unattended: Setup reads A:\winnt.sif (the answer floppy
// built from ./answer/ by fetch-deps.sh, key injected from .env) automatically.
// No guest agent on Win2000, so the build provision wscript only nudges the
// CD-boot prompt and watches the screen until the desktop appears.


template "windows-2000" {
  arch    = "x86"
  version = "2195.0"
  profile = "windows-9x"
  cpus    = 1
  memory  = 512MiB
  disk    = 10GiB

  source "iso" { path = "./iso/Windows-2000-Professional-SP4.iso" }
  // Unattended answer file: CD-boot Setup auto-reads A:\winnt.sif.
  media { kind = "floppy" from = "./windows-2000/answer/" label = "WINNT" }
  provision "windows-2000/scripts/install.ws" { }
}

// -----------------------------------------------------------------------------
// windows-3.11

// windows-3.11 template (PRD §6.1). Windows for Workgroups 3.11, layered on the
// dos-6.22 base (windows-9x profile: i440fx/SeaBIOS/IDE, Cirrus VGA, AMD PCnet).
//
// The ../iso payload is a *pre-installed* WfW 3.11 tree, not an installer, so
// there is no GUI setup to drive. fetch-deps.sh extracts it (patching the
// display driver from the unemulated S3 Trio to generic VGA) into ./win311/,
// which is built into the WIN311 media ISO. The build provision wscript boots the
// dos-6.22 disk, loads the CD driver that dos-6.22 already carries in C:\DOS,
// copies the WINDOWS tree onto C:, and configures DOS to launch Windows.


template "windows-3.11" {
  arch    = "x86"
  version = "3.11"
  profile = "windows-9x"
  cpus    = 1
  memory  = 64MiB
  disk    = 1GiB

  // Seed from the bootable MS-DOS 6.22 disk; its C:\DOS already holds the Oak
  // CD driver (cd1.sys) + MSCDEX that the install wscript uses to read the media.
  source "template" { from = "x86/dos-6.22" }

  // The extracted WfW 3.11 tree, surfaced to the guest as a CD-ROM.
  media { kind = "iso" from = "./windows-3.11/win311/" label = "WIN311" }

  provision "windows-3.11/scripts/install.ws" { }
}

// -----------------------------------------------------------------------------
// windows-7

// Windows 7 Enterprise template (PRD §6.1). Legacy guest: SeaBIOS + IDE + e1000
// (the windows-legacy profile), installed from a local MSDN/VL ISO in ../iso/.
// Win7 Enterprise installs keyless (no product key needed), so no .env entry.
//
// These old releases have no qemu guest agent, so the install is agent-free:
// autounattend.xml installs Windows and, on first logon, runs
// `sysprep /generalize /oobe /shutdown` itself; the build waits for the VM to
// power off and seals the generalized disk. Clones therefore boot generalized
// but without the vmlab guest agent (no `ready`/`exec`).


template "windows-7" {
  arch    = "x86_64"
  version = "7600.0"
  profile = "windows-legacy"
  cpus    = 2
  memory  = 4GiB
  disk    = 40GiB

  source "iso" { path = "./iso/en_windows_7_enterprise_x64_dvd_x15-70749.iso" }

  media { kind = "floppy" from = "./windows-7/unattend/" label = "UNATTEND" }
  nic { nat = true }

  provision "windows-7/scripts/install.ws" { }
}

