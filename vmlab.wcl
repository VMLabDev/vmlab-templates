//
// ISO pinned to the 25.11 channel build; sha256 from the .sha256 file
// published next to it on releases.nixos.org.


template "nixos-25.11" {
  arch    = "x86_64"
  version = "25.11"
  registry = "ghcr.io/vmlabdev/vmlab-templates/nixos-25.11"
  profile = "linux-modern"
  cpus    = 2
  memory  = 4GiB
