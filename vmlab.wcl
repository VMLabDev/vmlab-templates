// -----------------------------------------------------------------------------
// windows-server-2016

// Windows 7 Enterprise template (PRD §6.1). Legacy guest: SeaBIOS + IDE + e1000
// (the windows-legacy profile), installed from a local MSDN/VL ISO in ../iso/.
// Win7 Enterprise installs keyless (no product key needed), so no .env entry.
//
// These old releases have no qemu guest agent, so the install is agent-free:
// autounattend.xml installs Windows and, on first logon, runs
// `sysprep /generalize /oobe /shutdown` itself; the build waits for the VM to
// power off and seals the generalized disk. Clones therefore boot generalized
// but without the vmlab guest agent (no `ready`/`exec`).


template "windows-server-2016" {
  arch    = "x86_64"
  version = "14393.0"
  profile = "windows-legacy"
  cpus    = 2
  memory  = 4GiB
  disk    = 40GiB

  source "iso" { path = "./iso/en_windows_server_2016_x64_dvd_9327751.iso" }

  media { kind = "floppy" from = "./windows-server-2016/unattend/" label = "UNATTEND" }
  nic { nat = true }

  provision "windows-server-2016/scripts/install.ws" { }
}

// -----------------------------------------------------------------------------
// windows-server-2019

// Windows Server 2019 (Evaluation) template (PRD §6.1). Fully unattended:
// unattend/ is packed into an ISO carrying autounattend.xml, the virtio
// storage/net drivers Windows Setup needs (the windows-server profile uses
// virtio disk + NIC), and the guest tooling MSIs installed on first logon.
//
//   ./fetch-deps.sh        # one-time: pull virtio drivers + MSIs into unattend/
//   vmlab template build   # ~30-45 minutes
//
// The eval ISO is licensed for 180 days of evaluation — see README.md.


template "windows-server-2019" {
  arch    = "x86_64"
  version = "17763.737"
  registry = "ghcr.io/vmlabdev/vmlab-templates/windows-server-2019"
  profile = "windows-server"
  cpus    = 4
  memory  = 8GiB
  disk    = 60GiB

  source "iso" {
    url    = "https://software-static.download.prss.microsoft.com/pr/download/17763.737.190906-2324.rs5_release_svc_refresh_SERVER_EVAL_x64FRE_en-us_1.iso"
    sha256 = "549bca46c055157291be6c22a3aaaed8330e78ef4382c99ee82c896426a1cee1"
  }

  media { kind = "iso" from = "./windows-server-2019/unattend/" label = "UNATTEND" }
  nic { nat = true }

  provision "windows-server-2019/scripts/install.ws" { }

  // Runs on every clone's first boot, before the VM is reported ready: waits
  // for sysprep specialize/OOBE to finish (the specialize-pass marker), then
  // clears it. So labs using this template never see a half-specialized clone.
  first_boot = "windows-server-2019/scripts/firstboot.ws"
}

