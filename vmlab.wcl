// -----------------------------------------------------------------------------
// freedos-1.3

// freedos-1.3 template. FreeDOS 1.3 on the windows-9x profile (i440fx/SeaBIOS/IDE,
// Cirrus VGA, AMD PCnet NIC). Unlike the proprietary dos-6.22 entry, FreeDOS is
// FOSS / freely redistributable, so it carries a `registry` and is publishable.
//
// fetch-deps.sh downloads + sha256-verifies the official LiveCD zip and extracts
// FD13LIVE.iso (gitignored). FreeDOS has no answer file and no QEMU guest agent,
// so the build's FDI installer is driven over the live screen (VNC + OCR) by the
// provision wscript, just like dos-6.22.


template "freedos-1.3" {
  arch     = "x86"
  version  = "1.3"
  registry = "ghcr.io/vmlabdev/vmlab-templates/freedos-1.3"
  profile  = "windows-9x"
  cpus     = 1
  memory   = 64MiB        // FreeDOS is happy small; the LiveCD warns about its RAM
                          // drive even at 256M, so the bump buys nothing
  disk     = 2GiB         // Full install (BASE + apps/bonus) needs the room

  source "iso" { path = "./freedos-1.3/FD13LIVE.iso" }
  provision "freedos-1.3/scripts/install.ws" { }
}

// -----------------------------------------------------------------------------
// home-assistant-aarch64

// Home Assistant OS for aarch64, built from the official **generic-aarch64**
// image. The literal Raspberry Pi image (haos_rpi4-64) boots via U-Boot and
// will not run in a VM; generic-aarch64 is the same Home Assistant OS built
// for UEFI (GRUB2), so it boots on the QEMU `virt` machine — this is the
// image HA documents for QEMU/KVM. Runs under TCG on x86 hosts (no KVM).
//
// HAOS is a sealed appliance: no vmlab guest agent and no cloud-init, so
// vmlab cannot `exec`/provision into it. You drive it through its web UI —
// in a lab, forward a host port to the guest's :8123. This build just boots
// the pristine image once and seals it (first-boot setup re-runs in the lab).
//
//   vmlab template build        (run from this directory)
//
// sha256 is GitHub's published digest for the .qcow2.xz asset.


template "home-assistant" {
  arch     = "aarch64"
  version  = "17.3"
  registry = "ghcr.io/vmlabdev/vmlab-templates/home-assistant"
  profile  = "linux-modern"
  // Sealed appliance: no way to install the vmlab agent (no ready/exec).
  agent    = false
  firmware = "ovmf"
  cpus     = 2
  memory   = 2GiB
  disk     = 32GiB

  source "qcow2" {
    url    = "https://github.com/home-assistant/operating-system/releases/download/17.3/haos_generic-aarch64-17.3.qcow2.xz"
    sha256 = "f5b2f350557cfff91b4d2e33777b623c0203858d94a116b29962c8147ab456e5"
  }

  nic { nat = true }

  provision "home-assistant-aarch64/scripts/install.ws" { }
}

// -----------------------------------------------------------------------------
// kali

// Kali Linux template built from the official prebuilt QEMU image.
// Kali ships it 7z-compressed, so fetch-deps.sh downloads, verifies and
// extracts it first (vmlab URL sources need a raw qcow2):
//
//   ./fetch-deps.sh             # one-time: ~3.5G download into disk/
//   vmlab template build        (run from this directory)
//
// The provision script waits for the vmlab guest agent (preinstalled in
// Kali's QEMU image), adds the vmlab user and enables SSH.


template "kali" {
  arch    = "x86_64"
  version = "2026.1"
  registry = "ghcr.io/vmlabdev/vmlab-templates/kali"
  profile = "linux-generic"
  cpus    = 2
  memory  = 4GiB
  disk    = 40GiB

  source "qcow2" { path = "./kali/disk/kali.qcow2" }

  nic { nat = true }

  provision "kali/scripts/install.ws" { }
}

// -----------------------------------------------------------------------------
// nixos-25.11

// NixOS 25.11 template built from the official minimal installer ISO.
// The minimal ISO auto-logs-in a nixos user on tty1; the provision script
// types one command that mounts the NIXSETUP media ISO and runs
// install.sh from it (partition, nixos-install with ./nix/configuration.nix,
// power off). Build with:
//
