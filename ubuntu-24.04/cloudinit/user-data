#cloud-config
# Subiquity autoinstall (NoCloud, picked up from the CIDATA ISO).
# Credentials baked into the template: vmlab / vmlab.
autoinstall:
  version: 1
  locale: en_US.UTF-8
  keyboard:
    layout: us
  storage:
    layout:
      name: direct
  identity:
    hostname: ubuntu
    username: vmlab
    password: "$6$msm7717SQBFhDWd8$Or75iQS6wZyqEqcm3QhWTz8gktMIHyvDmqWhs8rATckOUtgRZyTfuQ5C2lPMKnN9PQGF5FxJwYDaU6wGafA/z0"
  ssh:
    install-server: true
    allow-pw: true
  # Match the predictable-name family rather than the build VM's PCI-derived
  # interface name. Clones can enumerate the same virtio NIC as enp0s3 or
  # enp0s4 depending on which optional devices their lab configuration adds.
  network:
    version: 2
    ethernets:
      all-en:
        match:
          name: "en*"
        dhcp4: true
  packages:
    - qemu-guest-agent
  late-commands:
    - curtin in-target -- systemctl enable qemu-guest-agent.service
  # Power off instead of rebooting back into the installer ISO; the build
  # seals the disk once the VM is down.
  shutdown: poweroff
