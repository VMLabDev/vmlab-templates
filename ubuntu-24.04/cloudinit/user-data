#cloud-config
# Subiquity autoinstall (NoCloud, picked up from the CIDATA ISO).
# Credentials baked into the template: vmlab / vmlab.
autoinstall:
  version: 1
  locale: en_US.UTF-8
  keyboard:
    layout: us
  storage:
    layout:
      name: direct
  identity:
    hostname: ubuntu
    username: vmlab
    password: "$6$msm7717SQBFhDWd8$Or75iQS6wZyqEqcm3QhWTz8gktMIHyvDmqWhs8rATckOUtgRZyTfuQ5C2lPMKnN9PQGF5FxJwYDaU6wGafA/z0"
  ssh:
    install-server: true
    allow-pw: true
  # Install the vmlab guest agent from the VMLAB bootstrap ISO into the
  # target (offline: copied + enabled; it starts on the installed system's
  # first boot — the build verifies it with an extra boot after sealing the
  # install).
  late-commands:
    - sh -c 'mkdir -p /media/vmlab && mount -o ro LABEL=VMLAB /media/vmlab && /media/vmlab/install.sh --root /target && umount /media/vmlab'
  # Power off instead of rebooting back into the installer ISO; the build
  # seals the disk once the VM is down.
  shutdown: poweroff
