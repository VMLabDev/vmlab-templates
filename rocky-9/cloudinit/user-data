#cloud-config
# NoCloud seed for the rocky-9 template build.
# Credentials baked into the template: vmlab / vmlab.
hostname: rocky
users:
  - name: vmlab
    shell: /bin/bash
    groups: [wheel]
    sudo: ALL=(ALL) NOPASSWD:ALL
    lock_passwd: false
    passwd: "$6$msm7717SQBFhDWd8$Or75iQS6wZyqEqcm3QhWTz8gktMIHyvDmqWhs8rATckOUtgRZyTfuQ5C2lPMKnN9PQGF5FxJwYDaU6wGafA/z0"
ssh_pwauth: true


runcmd:
  # Lab images run SELinux permissive: enforcing denies the guest agent
  # exec'ing most binaries, which breaks vmlab exec/provisioning.
  - [sh, -c, "setenforce 0 || true"]
  - sed -i 's/^SELINUX=enforcing/SELINUX=permissive/' /etc/selinux/config
  - |
    set -e
    mkdir -p /media/vmlab
    if ! mount -o ro LABEL=VMLAB /media/vmlab; then
      for d in /dev/sr0 /dev/sr1 /dev/sr2 /dev/vdb /dev/vdc /dev/vdd; do
        mount -o ro "$d" /media/vmlab 2>/dev/null || continue
        [ -e /media/vmlab/install.sh ] && break
        umount /media/vmlab
      done
    fi
    /media/vmlab/install.sh
    umount /media/vmlab
