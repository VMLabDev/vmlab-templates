// Smoke-test the windows-vista-x86 template: boot x86/windows-vista on a NAT'd segment and watch the
// console. Build or pull the template first, then from the repo root:
//
//   just example-up windows-vista-x86       # bring it up and open the console
//   just example-down windows-vista-x86     # tear it down
//
// Hardware (cpus / memory / firmware) is inherited from the template.

import <vmlab.wcl>

lab "windows-vista-x86" {

  segment "lan" {
    subnet = "10.99.0.0/24"
    nat    = true
  }

  vm "guest" {
    template = "x86/windows-vista"
    nic { segment = "lan" }
  }
}
