// Smoke-test the windows-8 template: boot x86_64/windows-8 on a NAT'd segment and watch the
// console. Build or pull the template first, then from the repo root:
//
//   just example-up windows-8       # bring it up and open the console
//   just example-down windows-8     # tear it down
//
// Hardware (cpus / memory / firmware) is inherited from the template.

import <vmlab.wcl>

lab "windows-8" {

  segment "lan" {
    subnet = "10.99.0.0/24"
    nat    = true
  }

  vm "guest" {
    template = "x86_64/windows-8"
    nic { segment = "lan" }
  }
}
