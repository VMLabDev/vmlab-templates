// Smoke-test the fedora-44 template: boot x86_64/fedora-44 on a NAT'd segment and watch the
// console. Build or pull the template first, then from the repo root:
//
//   just example-up fedora-44       # bring it up and open the console
//   just example-down fedora-44     # tear it down
//
// Hardware (cpus / memory / firmware) is inherited from the template.

import <vmlab.wcl>

lab "fedora-44" {

  segment "lan" {
    subnet = "10.99.0.0/24"
    nat    = true
  }

  vm "guest" {
    template = "x86_64/fedora-44"
    nic { segment = "lan" }
  }
}
