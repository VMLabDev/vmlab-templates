// Smoke-test the ubuntu-arm64 template: boot aarch64/ubuntu-24.04 on a NAT'd segment and watch the
// console. Build or pull the template first, then from the repo root:
//
//   just example-up ubuntu-arm64       # bring it up and open the console
//   just example-down ubuntu-arm64     # tear it down
//
// Hardware (cpus / memory / firmware) is inherited from the template.

import <vmlab.wcl>

lab "ubuntu-arm64" {

  segment "lan" {
    subnet = "10.99.0.0/24"
    nat    = true
  }

  vm "guest" {
    template = "aarch64/ubuntu-24.04"
    nic { segment = "lan" }
  }
}
